# Database Configuration
DB_URL=jdbc:mysql://${DB_HOST}:3306/course_recommender?useSSL=true&serverTimezone=UTC
DB_USER=your_db_user
DB_PASS=your_db_password

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_long

# APIs
YOUTUBE_API_KEY=your_youtube_api_key
GEMINI_API_KEY=your_gemini_api_key
UDEMY_CLIENT_ID=your_udemy_client_id
UDEMY_CLIENT_SECRET=your_udemy_client_secret

# Server
PORT=8080
